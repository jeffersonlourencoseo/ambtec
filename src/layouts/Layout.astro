---
import '@fontsource-variable/playfair-display';
import '@fontsource-variable/dm-sans';
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import SchemaLocalBusiness from '../components/SchemaLocalBusiness.astro';
import SchemaArticle from '../components/SchemaArticle.astro';
import SchemaService from '../components/SchemaService.astro';
import WhatsAppBtn from '../components/WhatsAppBtn.astro';
import SchemaBreadcrumb from '../components/SchemaBreadcrumb.astro';
import { SITE_CONFIG } from '../data/config.ts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article' | 'service';
  noindex?: boolean;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
    author?: string;
    tags?: string[];
  };
}

const props = Astro.props;

// BreadcrumbList logic
const pathname = Astro.url.pathname;
const breadcrumbNames: Record<string, string> = {
  blog: 'Blog',
  servicos: 'Serviços',
  sobre: 'Sobre',
  contato: 'Contato',
  faq: 'FAQ',
  privacidade: 'Privacidade',
  termos: 'Termos',
};

let breadcrumbItems: { name: string; url: string }[] = [];
if (pathname !== '/' && pathname !== '') {
  breadcrumbItems = [{ name: 'Início', url: SITE_CONFIG.site }];
  const segments = pathname.split('/').filter(Boolean);
  let currentPath = '';
  segments.forEach((segment, index) => {
    currentPath += `/${segment}`;
    const name =
      index === segments.length - 1 && props.title
        ? props.title.replace(/\s*\|\s*Ambtec$/, '').replace(/\s*—\s*.+$/, '')
        : (breadcrumbNames[segment] || segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '));
    breadcrumbItems.push({
      name,
      url: `${SITE_CONFIG.site}${currentPath}`,
    });
  });
}
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <SEO {...props} />
  {props.type === 'article' ? (
    <SchemaArticle
      title={props.title || SITE_CONFIG.seo.defaultTitle}
      description={props.description || SITE_CONFIG.seo.defaultDescription}
      url={`${SITE_CONFIG.site}${Astro.url.pathname}`}
      image={props.image ? (props.image.startsWith('http') ? props.image : `${SITE_CONFIG.site}${props.image}`) : undefined}
      publishedTime={props.article?.publishedTime || new Date()}
      modifiedTime={props.article?.modifiedTime}
      author={props.article?.author}
      tags={props.article?.tags}
    />
  ) : props.type === 'service' ? (
    <SchemaService
      name={props.title || ''}
      description={props.description || SITE_CONFIG.seo.defaultDescription}
      url={`${SITE_CONFIG.site}${Astro.url.pathname}`}
      image={props.image ? (props.image.startsWith('http') ? props.image : `${SITE_CONFIG.site}${props.image}`) : undefined}
    />
  ) : (
    <SchemaLocalBusiness />
  )}
  {breadcrumbItems.length > 0 && (
    <SchemaBreadcrumb items={breadcrumbItems} />
  )}
</head>
<body class="font-body antialiased text-neutral-ink bg-neutral-paper">
  <slot name="header" />
  <main class="overflow-x-hidden">
    <slot />
  </main>
  <slot name="footer" />
  <WhatsAppBtn />
</body>
</html>

<script is:inline>
  // Scroll reveal observer
  document.addEventListener('DOMContentLoaded', () => {
    const revealElements = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
    revealElements.forEach(el => observer.observe(el));
  });
</script>
