---
const navLinks = [
  { label: 'Serviços', href: '/servicos' },
  { label: 'Blog', href: '/blog' },
  { label: 'Sobre', href: '/sobre' },
  { label: 'Contato', href: '/contato' },
];
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-white/90 border-b border-gray-100">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="flex items-center justify-between h-20">
      <a
        href="/"
        class="text-2xl font-black text-accent-900 tracking-tighter hover:scale-105 active:scale-95 transition-all"
      >
        AMBTEC
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-600 hover:text-secondary-900 font-semibold tracking-tight hover:scale-105 active:scale-95 transition-all"
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contato"
          class="inline-flex items-center justify-center px-6 py-2.5 bg-secondary-900 text-white font-bold rounded-lg hover:bg-accent-900 hover:scale-105 active:scale-95 transition-all shadow-lg shadow-secondary-900/20"
        >
          Orçamento
        </a>
      </nav>

      <!-- Mobile Toggle -->
      <button
        id="mobile-menu-toggle"
        aria-label="Abrir menu"
        aria-expanded="false"
        class="md:hidden inline-flex items-center justify-center w-12 h-12 rounded-xl bg-gray-100 text-gray-900 hover:bg-gray-200 hover:scale-105 active:scale-95 transition-all"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Drawer -->
<div
  id="mobile-drawer"
  class="fixed inset-0 z-[999] hidden"
  aria-hidden="true"
>
  <!-- Backdrop -->
  <div id="mobile-backdrop" class="absolute inset-0 bg-accent-900/95 backdrop-blur-lg"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center h-full px-8">
    <!-- Close Button -->
    <button
      id="mobile-menu-close"
      aria-label="Fechar menu"
      class="absolute top-6 right-6 inline-flex items-center justify-center w-14 h-14 rounded-full bg-white/10 text-white hover:bg-white/20 hover:scale-110 active:scale-95 transition-all"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Nav Links -->
    <nav class="flex flex-col items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link text-3xl font-black text-white tracking-tighter hover:text-primary-400 hover:scale-105 active:scale-95 transition-all"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- WhatsApp CTA -->
    <a
      href="https://wa.me/+550000000000?text=Ol%C3%A1!%20Gostaria%20de%20solicitar%20um%20diagn%C3%B3stico%20ambiental."
      target="_blank"
      rel="noopener noreferrer"
      class="mt-12 inline-flex items-center justify-center px-8 py-5 bg-green-500 text-white font-bold rounded-2xl hover:bg-green-600 hover:scale-105 active:scale-95 transition-all shadow-xl shadow-green-500/30"
    >
      <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
      Solicitar Orçamento
    </a>
  </div>
</div>

<script is:inline>
  (function() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const drawer = document.getElementById('mobile-drawer');
    const closeBtn = document.getElementById('mobile-menu-close');
    const backdrop = document.getElementById('mobile-backdrop');
    const navLinks = document.querySelectorAll('.mobile-nav-link');

    function openMenu() {
      drawer.classList.remove('hidden');
      drawer.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      drawer.classList.add('hidden');
      drawer.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    backdrop.addEventListener('click', closeMenu);
    navLinks.forEach((link) => link.addEventListener('click', closeMenu));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !drawer.classList.contains('hidden')) {
        closeMenu();
      }
    });
  })();
</script>
