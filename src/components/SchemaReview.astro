---
interface Props {
  itemReviewed: string;
  reviews: {
    author: string;
    datePublished: string;
    reviewBody: string;
    reviewRating?: number;
  }[];
}

const { itemReviewed, reviews } = Astro.props;

const schemas = reviews.map((r) => ({
  '@context': 'https://schema.org',
  '@type': 'Review',
  author: {
    '@type': 'Person',
    name: r.author,
  },
  datePublished: r.datePublished,
  reviewBody: r.reviewBody,
  itemReviewed: {
    '@type': 'Organization',
    name: itemReviewed,
    url: 'https://licenciamentoambientalrio.com.br',
  },
  ...(r.reviewRating
    ? {
        reviewRating: {
          '@type': 'Rating',
          ratingValue: r.reviewRating,
          bestRating: 5,
        },
      }
    : {}),
}));
---

<>
  {schemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</>
