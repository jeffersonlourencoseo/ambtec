---
interface Props {
  name: string;
  role: string;
  text: string;
  initials: string;
}

const { name, role, text, initials } = Astro.props;
---

<div class="relative glass-card p-8 lg:p-10 rounded-3xl hover:shadow-lift transition-all duration-500">
  <div class="absolute top-8 right-8 text-gold-400/20">
    <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
    </svg>
  </div>

  <div class="flex items-center gap-1 mb-6">
    {Array.from({ length: 5 }).map(() => (
      <svg class="w-4 h-4 text-gold-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <p class="relative text-charcoal/80 leading-relaxed mb-8 text-lg italic font-display">"{text}"</p>

  <div class="flex items-center gap-4">
    <div class="w-12 h-12 rounded-full bg-gradient-to-br from-deep-900 to-forest-800 flex items-center justify-center text-gold-400 font-bold text-sm shadow-soft">{initials}</div>
    <div>
      <p class="font-bold text-charcoal text-sm">{name}</p>
      <p class="text-charcoal/50 text-xs">{role}</p>
    </div>
  </div>
</div>
