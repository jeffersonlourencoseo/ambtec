---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-12 lg:mb-16">
  <div class="deco-line mb-6"></div>
  <h2 class="text-3xl md:text-4xl font-display font-bold text-neutral-ink mb-5 tracking-tight">
    {title}
  </h2>
  {subtitle && (
    <p class="text-lg text-neutral-ink-muted max-w-3xl leading-relaxed">{subtitle}</p>
  )}
</div>
