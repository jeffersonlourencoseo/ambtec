---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-12 lg:mb-16">
  <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-5">
    {title}
  </h2>
  {subtitle && (
    <p class="text-lg text-gray-600 max-w-3xl leading-relaxed">{subtitle}</p>
  )}
</div>
