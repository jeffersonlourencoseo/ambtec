---
export interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 600 400"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <g opacity="0.06">
    <path
      d="M0 200 Q150 100 300 200 T600 200"
      stroke="currentColor"
      stroke-width="0.75"
      fill="none"
    />
    <path
      d="M0 200 Q150 300 300 200 T600 200"
      stroke="currentColor"
      stroke-width="0.75"
      fill="none"
    />
    <path
      d="M0 200 Q150 150 300 200 T600 200"
      stroke="currentColor"
      stroke-width="0.5"
      fill="none"
    />
    <path
      d="M0 200 Q150 250 300 200 T600 200"
      stroke="currentColor"
      stroke-width="0.5"
      fill="none"
    />
    <path
      d="M0 200 Q150 50 300 200 T600 200"
      stroke="currentColor"
      stroke-width="0.35"
      fill="none"
    />
    <path
      d="M0 200 Q150 350 300 200 T600 200"
      stroke="currentColor"
      stroke-width="0.35"
      fill="none"
    />
  </g>
  <g opacity="0.1">
    <circle cx="300" cy="200" r="180" stroke="currentColor" stroke-width="0.5" fill="none"/>
    <circle cx="300" cy="200" r="120" stroke="currentColor" stroke-width="0.5" fill="none"/>
    <circle cx="300" cy="200" r="60" stroke="currentColor" stroke-width="0.5" fill="none"/>
  </g>
</svg>
