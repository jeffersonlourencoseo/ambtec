---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;
---

<div class="bg-white border border-gray-100 rounded-2xl p-10 lg:p-12 shadow-sm hover:shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-all duration-300">
  {icon && (
    <div class="mb-6 text-primary-500">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
      </svg>
    </div>
  )}
  <h3 class="text-xl font-bold text-gray-900 mb-4 tracking-tight">{title}</h3>
  <p class="text-gray-600 leading-relaxed">{description}</p>
</div>
