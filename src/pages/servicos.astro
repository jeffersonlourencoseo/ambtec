---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';
import { SITE_CONFIG } from '../data/config.ts';

const servicos = await getCollection('servicos');
---

<Layout
  title={`Serviços — ${SITE_CONFIG.company.name}`}
  description={`Conheça todos os serviços de consultoria ambiental da ${SITE_CONFIG.company.shortName}: licenciamento, EIA/RIMA, CAR, gestão e auditoria ambiental.`}
>
  <Fragment slot="header"><Header /></Fragment>

  <!-- HERO -->
  <section class="relative bg-deep-900 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>
    <div class="absolute top-1/3 -right-32 w-96 h-96 bg-gold-400/5 rounded-full blur-3xl"></div>
    <div class="section-luxury relative z-10">
      <div class="section-inner">
        <div class="max-w-4xl">
          <div class="deco-line mb-8"></div>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white tracking-tight leading-[0.95] mb-8">
            Nossos <span class="text-gradient-gold">Serviços</span>
          </h1>
          <p class="text-xl text-white/50 max-w-2xl leading-relaxed">
            Do licenciamento ambiental à regularização junto ao INEA e Secretarias Municipais, oferecemos expertise técnica para indústria, construção, comércio e empreendimentos imobiliários.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- GRID DE SERVIÇOS -->
  <section class="section-luxury bg-paper">
    <div class="section-inner">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {servicos.map((servico) => (
          <a href={`/servicos/${servico.slug}`} class="group">
            <Card
              title={servico.data.title}
              description={servico.data.description}
              icon={servico.data.icon}
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-luxury bg-cream">
    <div class="section-inner">
      <div class="text-center">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6">Não encontrou o que precisa?</h2>
        <p class="text-charcoal/50 max-w-xl mx-auto mb-10">Cada empreendimento é único. Fale com nossos especialistas para uma avaliação personalizada.</p>
        <a href="/contato" class="btn-luxury">Solicitar Proposta Técnica</a>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
