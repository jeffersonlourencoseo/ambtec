---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';
import { SITE_CONFIG } from '../data/config.ts';

const todosServicos = await getCollection('servicos');
const servicos = [
  todosServicos.find(s => s.slug === 'licenciamento-ambiental'),
  ...todosServicos.filter(s => s.slug !== 'licenciamento-ambiental')
].filter(Boolean);
---

<Layout
  title="Serviços de Licenciamento e Consultoria Ambiental"
  description={`Conheça os serviços da ${SITE_CONFIG.company.shortName}: licenciamento ambiental, compensação, inventário florestal, podas e reflorestamento — tudo interligado para regularizar seu empreendimento no RJ.`}
>
  <Fragment slot="header"><Header /></Fragment>

  <!-- HERO -->
  <section class="relative bg-deep-900 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>
    <div class="absolute top-1/3 -right-32 w-96 h-96 bg-gold-400/5 rounded-full blur-3xl"></div>
    <div class="section-luxury relative z-10">
      <div class="section-inner">
        <div class="max-w-4xl">
          <div class="deco-line mb-8"></div>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white tracking-tight leading-[0.95] mb-8">
            Nossos <span class="text-gradient-gold">Serviços</span>
          </h1>
          <p class="text-xl text-white/50 max-w-2xl leading-relaxed">
            O <strong class="text-white/80">licenciamento ambiental</strong> é o núcleo da regularização. Para licenciar, seu empreendimento pode precisar de compensação ambiental, inventário florestal, poda de árvores autorizada ou reflorestamento. Na Ambtec, tudo isso está em um só lugar — técnica, burocracia e execução prática interligadas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- GRID DE SERVIÇOS -->
  <section class="section-luxury bg-paper">
    <div class="section-inner">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {servicos.map((servico) => (
          <a href={`/servicos/${servico.slug}`} class="group">
            <Card
              title={servico.data.title}
              description={servico.data.description}
              icon={servico.data.icon}
            />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-luxury bg-cream">
    <div class="section-inner">
      <div class="text-center">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-6">Não encontrou o que precisa?</h2>
        <p class="text-charcoal/50 max-w-xl mx-auto mb-10">Cada empreendimento é único. Fale com nossos especialistas para uma avaliação personalizada.</p>
        <a href="/contato" class="btn-luxury">Solicitar Proposta Técnica</a>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
