---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import CTABox from '../../components/CTABox.astro';
import SchemaFAQ from '../../components/SchemaFAQ.astro';
import SchemaHowTo from '../../components/SchemaHowTo.astro';
import { getCollection } from 'astro:content';
import { SITE_CONFIG } from '../../data/config.ts';

export const prerender = true;

export async function getStaticPaths() {
  const servicos = await getCollection('servicos');
  return servicos.map((servico) => ({
    params: { slug: servico.slug },
    props: { servico },
  }));
}

const { servico } = Astro.props;
const { Content } = await servico.render();

const howToSteps: Record<string, { name: string; text: string }[]> = {
  'licenciamento-ambiental': [
    { name: 'Diagnóstico inicial', text: 'Análise do empreendimento, documentação existente e classificação do porte segundo a CONAMA 401/2008.' },
    { name: 'Elaboração de estudos', text: 'Preparação de EIA, RIMA, RAS ou outros estudos exigidos conforme o porte e tipologia.' },
    { name: 'Protocolo no órgão ambiental', text: 'Submissão da documentação ao INEA ou Secretaria Municipal de Meio Ambiente e acompanhamento técnico.' },
    { name: 'Execução de condicionantes', text: 'Compensação ambiental, inventário, podas ou reflorestamento quando exigido na licença.' },
    { name: 'Acompanhamento pós-licenciamento', text: 'Monitoramento de condicionantes, relatórios periódicos e renovações de licenças.' },
  ],
  'compensacao-ambiental': [
    { name: 'Mapeamento das áreas impactadas', text: 'Vistoria técnica, georreferenciamento e análise do uso do solo para identificar áreas afetadas.' },
    { name: 'Cálculo técnico', text: 'Quantificação da compensação exigida considerando área, bioma e serviços ecossistêmicos perdidos.' },
    { name: 'Elaboração do plano', text: 'Desenvolvimento do Plano de Compensação Ambiental com ações: RPPN, restauração florestal ou CRAs.' },
    { name: 'Execução e monitoramento', text: 'Implantação das ações compensatórias com acompanhamento técnico de plantio, fauna e fitossociologia.' },
    { name: 'Regularização final', text: 'Entrega de relatórios, certificações e documentação para comprovação junto aos órgãos ambientais.' },
  ],
  'inventario-florestal-e-fauna': [
    { name: 'Planejamento metodológico', text: 'Definição do universo amostral, parcelas, período de coleta e equipe especializada.' },
    { name: 'Execução de campo', text: 'Coletas, medições, fotografias e registros sonoros por biólogos e técnicos especializados.' },
    { name: 'Identificação laboratorial', text: 'Processamento de amostras e validação taxonômica com especialistas e coleções científicas.' },
    { name: 'Análise de dados', text: 'Tratamento estatístico, SIG, mapas e índices de diversidade (Shannon, Simpson).' },
    { name: 'Relatório técnico', text: 'Documentação completa para protocolo em licenciamentos, regularizações e publicações científicas.' },
  ],
  'podas-e-supressao-vegetal': [
    { name: 'Vistoria técnica in loco', text: 'Avaliação da saúde das árvores, riscos, espécies, DAP e localização por engenheiro florestal credenciado.' },
    { name: 'Identificação botânica', text: 'Catalogação de espécies e verificação de exemplares raras, ameaçados ou protegidos.' },
    { name: 'Elaboração do laudo', text: 'Laudo técnico com justificativa, fotos, identificação, DAP, estado fitossanitário e recomendações.' },
    { name: 'Solicitação de autorização', text: 'Protocolo do pedido junto ao INEA ou Secretaria Municipal e acompanhamento até aprovação.' },
    { name: 'Execução e relatório', text: 'Poda ou supressão com equipe treinada, EPIs adequados e entrega de relatório fotográfico final.' },
  ],
  'reflorestamento': [
    { name: 'Diagnóstico do solo e clima', text: 'Análise física, química e biológica do solo e variáveis climáticas locais.' },
    { name: 'Seleção de espécies nativas', text: 'Escolha de espécies pioneiras, secundárias e climácicas adequadas ao bioma local.' },
    { name: 'Preparo e plantio', text: 'Preparo físico do solo, correção de acidez, adubação orgânica e plantio em densidades ecológicas.' },
    { name: 'Monitoramento e manutenção', text: 'Acompanhamento periódico da sobrevivência, controle de pragas, replantio e regeneração natural.' },
    { name: 'Relatórios e certificações', text: 'Documentação técnica com ART, relatórios fotográficos e laudos de conclusão para órgãos ambientais.' },
  ],
};

const beneficios = [
  { title: 'Conformidade Legal Garantida', desc: 'Seu empreendimento 100% dentro das normas ambientais federais, estaduais e municipais.', icon: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  { title: 'Prazos Curtos e Definidos', desc: 'Cronograma realista com acompanhamento semanal. Você sabe exatamente quando sua licença sai.', icon: 'M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z' },
  { title: 'Documentação Completa', desc: 'Entregamos todo o conjunto documental pronto para protocolo ou implementação.', icon: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z' },
  { title: 'Suporte Pós-Licenciamento', desc: 'Acompanhamento contínuo para renovações, condicionantes e novas demandas ambientais.', icon: 'M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99' },
];
---

<Layout
  type="service"
  title={servico.data.title}
  description={servico.data.description}
>
  <Fragment slot="header"><Header /></Fragment>

  <SchemaFAQ
    questions={[
      {
        question: `Quanto tempo leva ${servico.data.title.toLowerCase()}?`,
        answer: 'O prazo médio varia conforme o porte do empreendimento e a complexidade técnica. Após diagnóstico gratuito, apresentamos cronograma realista com acompanhamento semanal.',
      },
      {
        question: `Quanto custa ${servico.data.title.toLowerCase()} no Rio de Janeiro?`,
        answer: 'Cada projeto recebe proposta técnica personalizada após diagnóstico inicial. Os valores variam conforme porte, complexidade e escopo. Consulte nossa tabela de preços orientativas ou solicite uma proposta.',
      },
      {
        question: 'Como começar o processo com a Ambtec?',
        answer: 'Solicite o diagnóstico gratuito via WhatsApp (21) 99835-1294 ou formulário em /contato. Nossa equipe técnica analisa seu empreendimento e apresenta proposta detalhada com cronograma e investimento.',
      },
    ]}
  />

  <!-- HERO -->
  <section class="relative bg-brand-deep overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>
    <div class="absolute top-1/3 -right-32 w-96 h-96 bg-accent-gold/5 rounded-full blur-3xl"></div>
    <div class="section-luxury relative z-10">
      <div class="section-inner">
        <div class="max-w-4xl">
          <div class="inline-flex items-center gap-3 px-5 py-2.5 mb-8 rounded-full border border-accent-gold/20 bg-accent-gold/5 backdrop-blur-sm">
            <span class="text-accent-gold text-sm font-medium tracking-wide uppercase">Serviço Especializado</span>
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-white tracking-tight leading-tight mb-8">
            {servico.data.title}
          </h1>
          <p class="text-xl text-white/50 max-w-3xl leading-relaxed">
            {servico.data.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  {howToSteps[servico.slug] && (
    <SchemaHowTo
      name={`Como funciona ${servico.data.title.toLowerCase()} na Ambtec`}
      description={`Passo a passo do processo técnico de ${servico.data.title.toLowerCase()} no Rio de Janeiro.`}
      steps={howToSteps[servico.slug]}
    />
  )}

  <!-- CONTEÚDO -->
  <section class="section-luxury bg-neutral-cream">
    <div class="section-inner">
      <div class="max-w-4xl mx-auto mb-8">
        <span class="text-xs text-neutral-ink-muted">
          Última atualização: {new Date().toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </span>
      </div>
      <article class="prose prose-lg max-w-4xl mx-auto text-neutral-ink-muted">
        <Content />
      </article>
    </div>
  </section>

  <!-- BENEFÍCIOS -->
  <section class="section-luxury bg-neutral-paper">
    <div class="section-inner">
      <div class="text-center mb-20">
        <div class="deco-line mx-auto mb-8"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-neutral-ink mb-6 tracking-tight">Por que contratar este serviço?</h2>
        <p class="text-lg text-neutral-ink-muted max-w-2xl mx-auto">Benefícios reais que sua empresa vai perceber desde o primeiro dia.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {beneficios.map((b) => (
          <div class="card-surface p-8 rounded-xl flex items-start gap-6">
            <div class="shrink-0 w-14 h-14 bg-gradient-to-br from-brand-deep to-brand-mid rounded-2xl flex items-center justify-center text-accent-gold shadow-soft">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={b.icon} /></svg>
            </div>
            <div>
              <h3 class="text-lg font-display font-bold text-neutral-ink mb-2">{b.title}</h3>
              <p class="text-neutral-ink-muted text-sm leading-relaxed">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-luxury bg-neutral-cream">
    <div class="section-inner">
      <CTABox
        title={`Quer contratar ${servico.data.title.toLowerCase()}?`}
        subtitle="Fale com um especialista agora mesmo. Solicite uma proposta técnica personalizada."
      />
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
