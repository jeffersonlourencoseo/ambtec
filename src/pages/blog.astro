---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { getCollection } from 'astro:content';
import { SITE_CONFIG } from '../data/config.ts';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout
  title={`Blog — ${SITE_CONFIG.company.name}`}
  description="Artigos, guias e novidades sobre licenciamento ambiental, CAR, gestão sustentável e regularização ambiental."
>
  <Fragment slot="header"><Header /></Fragment>

  <!-- HERO -->
  <section class="relative bg-brand-deep overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>
    <div class="absolute bottom-1/3 -left-32 w-96 h-96 bg-accent-gold/5 rounded-full blur-3xl"></div>
    <div class="section-luxury relative z-10">
      <div class="section-inner">
        <div class="max-w-4xl">
          <div class="deco-line mb-8"></div>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white tracking-tight leading-[0.95] mb-8">
            Blog <span class="text-accent-gold">Ambiental</span>
          </h1>
          <p class="text-xl text-white/50 max-w-2xl leading-relaxed">
            Conteúdo técnico para decisões inteligentes. Artigos sobre licenciamento, CAR, avaliação de impacto e gestão ambiental.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LISTA DE POSTS -->
  <section class="section-luxury bg-neutral-paper">
    <div class="section-inner">
      <h2 class="sr-only">Últimos Artigos sobre Licenciamento Ambiental</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {posts.map((post, index) => (
          <a href={`/blog/${post.slug}`} class="group block">
            <article class="card-surface p-8 lg:p-10 rounded-xl hover:shadow-lift transition-all duration-500 h-full">
              <div class="flex items-center gap-3 mb-5">
                <span class="text-xs font-bold uppercase tracking-wider text-accent-gold-deep bg-accent-gold/10 px-3 py-1 rounded-full">
                  {post.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' })}
                </span>
              </div>
              <h3 class="text-2xl font-display font-bold text-neutral-ink mb-4 group-hover:text-brand-mid transition-colors duration-300">{post.data.title}</h3>
              <p class="text-neutral-ink-muted leading-relaxed">{post.data.description}</p>
              <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-brand-mid group-hover:text-accent-gold-deep transition-colors duration-300">
                <span>Ler artigo</span>
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
