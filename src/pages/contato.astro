---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE_CONFIG } from '../data/config.ts';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.company.whatsapp}?text=${encodeURIComponent('Olá, vi o site no google e gostaria de mais informações!')}`;
---

<Layout
  title={`Contato — ${SITE_CONFIG.company.name}`}
  description={`Entre em contato com a ${SITE_CONFIG.company.shortName}. Solicite uma proposta técnica e descubra como regularizar seu empreendimento com segurança jurídica.`}
>
  <Fragment slot="header"><Header /></Fragment>

  <!-- HERO -->
  <section class="relative bg-brand-deep overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>
    <div class="absolute top-1/3 -right-32 w-96 h-96 bg-accent-gold/5 rounded-full blur-3xl"></div>
    <div class="section-luxury relative z-10">
      <div class="section-inner">
        <div class="max-w-4xl">
          <div class="deco-line mb-8"></div>
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-display font-bold text-white tracking-tight leading-[0.95] mb-8">
            Entre em <span class="text-accent-gold">Contato</span>
          </h1>
          <p class="text-xl text-white/50 max-w-2xl leading-relaxed">
            Fale com nossa equipe de especialistas. Estamos prontos para conduzir seu projeto do diagnóstico à licença aprovada.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTEÚDO -->
  <section class="section-luxury bg-neutral-paper">
    <div class="section-inner">
      <h2 class="sr-only">Informações de Contato</h2>
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- INFO -->
        <div class="lg:col-span-2 space-y-8">
          <div class="card-surface p-8 lg:p-10 rounded-xl">
            <h3 class="text-xl font-display font-bold text-neutral-ink mb-8">Fale Conosco</h3>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-accent-gold/10 flex items-center justify-center text-accent-gold shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-neutral-ink text-sm">Telefone / WhatsApp</p>
                  <a href={`tel:${SITE_CONFIG.company.phone}`} class="text-neutral-ink-muted hover:text-brand-mid transition-colors text-sm">{SITE_CONFIG.company.phoneFormatted}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-accent-gold/10 flex items-center justify-center text-accent-gold shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-neutral-ink text-sm">E-mail</p>
                  <a href={`mailto:${SITE_CONFIG.company.email}`} class="text-neutral-ink-muted hover:text-brand-mid transition-colors text-sm">{SITE_CONFIG.company.email}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-accent-gold/10 flex items-center justify-center text-accent-gold shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
                </div>
                <div>
                  <p class="font-semibold text-neutral-ink text-sm">Endereço</p>
                  <span class="text-neutral-ink-muted text-sm">{SITE_CONFIG.company.address.street} — {SITE_CONFIG.company.address.neighborhood}<br/>{SITE_CONFIG.company.address.city} — {SITE_CONFIG.company.address.state}<br/>CEP: {SITE_CONFIG.company.address.zipCode}</span>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-accent-gold/10 flex items-center justify-center text-accent-gold shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div>
                  <p class="font-semibold text-neutral-ink text-sm">Horário de Atendimento</p>
                  <span class="text-neutral-ink-muted text-sm">Segunda a Sexta: 08h às 18h<br/>Sábado: 09h às 13h</span>
                </div>
              </div>
            </div>
          </div>

          <div class="relative overflow-hidden rounded-2xl p-8 lg:p-10 bg-gradient-to-br from-brand-deep to-brand-mid text-white">
            <div class="absolute inset-0 noise-overlay"></div>
            <div class="relative z-10">
              <h3 class="text-xl font-display font-bold mb-3">Prefere o WhatsApp?</h3>
              <p class="text-white/50 mb-6 text-sm">
                Resposta rápida para dúvidas e solicitações de orçamento.
              </p>
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center p-5 bg-accent-gold text-brand-deep font-bold rounded-xl hover:bg-accent-gold-deep transition-colors w-full"
              >
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                Abrir WhatsApp
              </a>
            </div>
          </div>
        </div>

        <!-- FORMULÁRIO -->
        <div class="lg:col-span-3">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
