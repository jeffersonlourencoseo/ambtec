---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Contato — Ambtec Licenciamento Ambiental"
  description="Entre em contato com a Ambtec. Solicite um diagnóstico ambiental gratuito e descubra como regularizar seu empreendimento."
>
  <Fragment slot="header"><Header /></Fragment>

  <section>
    <div class="section-inner">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter leading-tight mb-16 text-gray-900">
        Entre em <span class="text-secondary-900">Contato</span>
      </h1>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-12">
        <!-- NAP + INFORMAÇÕES -->
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-gray-50 rounded-2xl p-10 lg:p-12">
            <h3 class="text-xl font-bold text-gray-900 mb-6">Fale Conosco</h3>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary-100 flex items-center justify-center text-primary-600 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Telefone / WhatsApp</p>
                  <p class="text-gray-600"><a href="tel:+550000000000" class="hover:text-secondary-900 transition-colors">(00) 00000-0000</a></p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary-100 flex items-center justify-center text-primary-600 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">E-mail</p>
                  <p class="text-gray-600"><a href="mailto:contato@ambtec.com.br" class="hover:text-secondary-900 transition-colors">contato@ambtec.com.br</a></p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary-100 flex items-center justify-center text-primary-600 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Endereço</p>
                  <p class="text-gray-600">Rua das Acácias, 123 — Centro<br />Cidade Ambiental — Estado<br />CEP: 00000-000</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-xl bg-primary-100 flex items-center justify-center text-primary-600 shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-gray-900">Horário de Atendimento</p>
                  <p class="text-gray-600">Segunda a Sexta: 08h às 18h<br />Sábado: 09h às 13h</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-secondary-900 rounded-2xl p-10 lg:p-12 text-white">
            <h3 class="text-xl font-bold mb-4">Prefere o WhatsApp?</h3>
            <p class="text-gray-300 mb-6">
              Resposta rápida para dúvidas e solicitações de orçamento. Clique no botão abaixo.
            </p>
            <a
              href="https://wa.me/+550000000000?text=Ol%C3%A1!%20Gostaria%20de%20solicitar%20um%20diagn%C3%B3stico%20ambiental."
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center p-6 bg-green-500 text-white font-bold rounded-xl hover:bg-green-600 transition-colors w-full"
            >
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              Abrir WhatsApp
            </a>
          </div>
        </div>

        <!-- FORMULÁRIO -->
        <div class="lg:col-span-3">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
