---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import SchemaFAQ from '../../components/SchemaFAQ.astro';
import { getCollection } from 'astro:content';
import { SITE_CONFIG } from '../../data/config.ts';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.title !== post.data.title);
const relatedPosts = allPosts.slice(0, 3);

const whatsappUrl = `https://wa.me/${SITE_CONFIG.company.whatsapp}?text=${encodeURIComponent('Olá, vi o site no google e gostaria de mais informações')}`;
---

<Layout
  type="article"
  title={post.data.title}
  description={post.data.description}
  article={{
    publishedTime: post.data.pubDate,
    modifiedTime: post.data.updatedDate,
    author: post.data.author,
    tags: post.data.tags,
  }}
>
  <Fragment slot="header"><Header /></Fragment>

  <SchemaFAQ
    questions={[
      {
        question: 'Esse processo é obrigatório no Rio de Janeiro?',
        answer: 'Sim. Conforme a legislação ambiental brasileira (Lei 6.938/81, CONAMA, Código Florestal), empresas e empreendimentos que causem impacto ambiental devem estar regularizadas junto ao INEA ou à Secretaria Municipal de Meio Ambiente de seu município.',
      },
      {
        question: 'Quanto tempo leva esse processo no RJ?',
        answer: 'O prazo médio varia de 3 a 12 meses, dependendo do porte do empreendimento, da complexidade dos estudos técnicos exigidos e do órgão licenciador. Empreendimentos de menor impacto costumam levar 3 a 6 meses, enquanto os de grande porte podem ultrapassar 12 meses.',
      },
      {
        question: 'Quanto custa esse serviço no Rio de Janeiro?',
        answer: 'Cada projeto recebe proposta técnica personalizada após diagnóstico inicial. O investimento varia conforme o porte do empreendimento, a quantidade de estudos exigidos e o prazo desejado. Solicite uma proposta sem compromisso.',
      },
    ]}
  />

  <section class="section-luxury bg-paper">
    <div class="section-inner">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
          <!-- CONTEÚDO PRINCIPAL -->
          <div class="lg:col-span-8">
            <div class="flex items-center gap-3 mb-8">
              <span class="text-xs font-bold uppercase tracking-wider text-gold-600 bg-gold-400/10 px-3 py-1 rounded-full">
                {post.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
              {post.data.updatedDate && (
                <span class="text-xs text-charcoal/40">
                  Atualizado em {post.data.updatedDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
                </span>
              )}
            </div>

            <h1 class="text-4xl md:text-5xl font-display font-bold tracking-tight leading-tight mb-16 text-charcoal">
              {post.data.title}
            </h1>

            <article class="prose prose-lg text-charcoal/70">
              <Content />
            </article>

            <div class="mt-16 pt-10 border-t border-charcoal/10">
              <a
                href="/blog"
                class="inline-flex items-center justify-center px-8 py-4 border border-charcoal/10 text-charcoal font-semibold rounded-full hover:border-deep-700 hover:text-deep-700 transition-colors"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
                Voltar para o Blog
              </a>
            </div>
          </div>

          <!-- SIDEBAR -->
          <aside class="lg:col-span-4 space-y-8">
            <div class="relative overflow-hidden rounded-3xl p-8 bg-gradient-to-br from-deep-900 to-forest-800 text-white sticky top-28">
              <div class="absolute inset-0 noise-overlay"></div>
              <div class="relative z-10">
                <h3 class="text-xl font-display font-bold mb-3">Precisa de ajuda ambiental?</h3>
                <p class="text-white/50 mb-6 text-sm leading-relaxed">
                  Nossa equipe oferece proposta técnica personalizada. Descubra o caminho mais rápido para regularizar seu empreendimento.
                </p>
                <a
                  href={whatsappUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center p-5 bg-gold-500 text-deep-900 font-bold rounded-xl hover:bg-gold-400 transition-colors w-full"
                >
                  Solicitar Orçamento
                </a>
              </div>
            </div>

            <div class="glass-card p-8 rounded-3xl">
              <h3 class="text-lg font-display font-bold text-charcoal mb-5">Serviços Populares</h3>
              <ul class="space-y-3">
                <li><a href="/servicos/licenciamento-ambiental" class="text-charcoal/60 hover:text-deep-700 transition-colors text-sm">Licenciamento Ambiental</a></li>
                <li><a href="/servicos/compensacao-ambiental" class="text-charcoal/60 hover:text-deep-700 transition-colors text-sm">Compensação Ambiental</a></li>
                <li><a href="/servicos/reflorestamento" class="text-charcoal/60 hover:text-deep-700 transition-colors text-sm">Reflorestamento</a></li>
                <li><a href="/servicos/podas-e-supressao-vegetal" class="text-charcoal/60 hover:text-deep-700 transition-colors text-sm">Podas e Supressão</a></li>
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <!-- POSTS RELACIONADOS -->
  {relatedPosts.length > 0 && (
    <section class="section-luxury bg-cream">
      <div class="section-inner">
        <div class="max-w-6xl mx-auto">
          <div class="deco-line mb-8"></div>
          <h2 class="text-3xl font-display font-bold text-charcoal mb-12 tracking-tight">Outras dicas ambientais</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedPosts.map((rp) => (
              <a href={`/blog/${rp.slug}`} class="group block">
                <article class="glass-card p-8 rounded-3xl hover:shadow-lift transition-all duration-500 h-full">
                  <div class="text-xs font-bold uppercase tracking-wider text-gold-600 bg-gold-400/10 px-3 py-1 rounded-full inline-block mb-4">
                    {rp.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' })}
                  </div>
                  <h3 class="text-xl font-display font-bold text-charcoal mb-3 group-hover:text-deep-700 transition-colors">{rp.data.title}</h3>
                  <p class="text-charcoal/60 text-sm leading-relaxed">{rp.data.description}</p>
                </article>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
