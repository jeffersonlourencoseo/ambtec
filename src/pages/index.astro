---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Card from '../components/Card.astro';
import DiferencialCard from '../components/DiferencialCard.astro';
import DepoimentoCard from '../components/DepoimentoCard.astro';
import CTABox from '../components/CTABox.astro';
import SchemaReview from '../components/SchemaReview.astro';
import { getCollection } from 'astro:content';
import { SITE_CONFIG } from '../data/config.ts';

const servicos = await getCollection('servicos');
const whatsappUrl = `https://wa.me/${SITE_CONFIG.company.whatsapp}?text=${encodeURIComponent('Olá, vi o site no google e gostaria de mais informações!')}`;
---

<Layout
  title={SITE_CONFIG.seo.defaultTitle}
  description={SITE_CONFIG.seo.defaultDescription}
>
  <Fragment slot="header"><Header /></Fragment>

  <SchemaReview
    itemReviewed={SITE_CONFIG.company.name}
    reviews={[
      {
        author: 'Roberto Mendes',
        datePublished: '2026-06-01',
        reviewBody: 'A Ambtec conduziu todo o processo de licenciamento da nossa indústria com extrema competência. Conseguimos a liberação dentro do prazo e sem retrabalho.',
        reviewRating: 5,
      },
      {
        author: 'Luciana Costa',
        datePublished: '2026-06-01',
        reviewBody: 'Profissionalismo e transparência em cada etapa. O licenciamento ambiental da nossa empresa foi resolvido sem complicações e hoje operamos 100% regularizados.',
        reviewRating: 5,
      },
      {
        author: 'Fernando Oliveira',
        datePublished: '2026-06-01',
        reviewBody: 'Contratamos para o EIA/RIMA de um grande empreendimento. O rigor técnico impressionou até os órgãos ambientais. Resultado: aprovação na primeira submissão.',
        reviewRating: 5,
      },
    ]}
  />

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center bg-deep-900 overflow-hidden">
    <div class="absolute inset-0 noise-overlay"></div>
    <img
      src="/images/hero-ambiental.webp"
      alt="Vista aérea de floresta tropical e vegetação nativa no Rio de Janeiro"
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-deep-900/90 via-deep-900/80 to-forest-900/70"></div>

    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-gold-400/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-forest-800/20 rounded-full blur-3xl"></div>

    <div class="section-luxury relative z-10 w-full">
      <div class="section-inner">
        <div class="max-w-4xl">
          <div class="inline-flex items-center gap-3 px-5 py-2.5 mb-10 rounded-full border border-gold-400/20 bg-gold-400/5 backdrop-blur-sm">
            <span class="w-2 h-2 rounded-full bg-gold-400 animate-pulse"></span>
            <span class="text-gold-300 text-sm font-medium tracking-wide uppercase">Referência em Consultoria Ambiental no Rio</span>
          </div>

          <h1 class="text-5xl md:text-6xl lg:text-8xl font-display font-bold text-white tracking-tight leading-[0.95] mb-8">
            Regularize seu
            <br />
            <span class="text-gradient-gold">Empreendimento</span>
          </h1>

            <p class="text-lg md:text-xl text-white/50 max-w-xl mb-12 leading-relaxed font-light">
            Licenciamento ambiental no Rio de Janeiro junto ao <span class="text-white/80 font-medium">INEA e Secretarias Municipais de Meio Ambiente</span>. Regularizamos indústrias, construção civil, comércios e empreendimentos imobiliários.
          </p>

          <div class="flex flex-wrap gap-4">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-luxury"
            >
              Solicitar Orçamento
            </a>
            <a
              href="/servicos"
              class="btn-luxury-dark"
            >
              Conhecer Serviços
            </a>
          </div>

          <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-8 border-t border-white/10 pt-10">
            <div>
              <div class="text-3xl md:text-4xl font-display font-bold text-gold-400 mb-1">200+</div>
              <div class="text-sm text-white/40">Empreendimentos Regularizados</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-display font-bold text-gold-400 mb-1">98%</div>
              <div class="text-sm text-white/40">Taxa de Aprovação</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-display font-bold text-gold-400 mb-1">15+</div>
              <div class="text-sm text-white/40">Anos de Experiência</div>
            </div>
            <div>
              <div class="text-3xl md:text-4xl font-display font-bold text-gold-400 mb-1">5</div>
              <div class="text-sm text-white/40">Especialidades Técnicas</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIFERENCIAIS -->
  <section class="section-luxury bg-paper">
    <div class="section-inner">
      <div class="text-center mb-20">
        <div class="deco-line mx-auto mb-8"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-charcoal mb-6 tracking-tight">
          Por que empresas confiam na {SITE_CONFIG.company.shortName}?
        </h2>
        <p class="text-lg text-charcoal/50 max-w-2xl mx-auto">Técnica, experiência e compromisso com prazos e conformidade legal em cada projeto.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        <DiferencialCard
          title="Diagnóstico Técnico Especializado"
          description="Após o primeiro contato, nossa equipe técnica analisa as particularidades do seu empreendimento e apresenta uma proposta detalhada com cronograma realista."
          icon="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
        />
        <DiferencialCard
          title="Equipe Multidisciplinar"
          description="Engenheiros ambientais e biólogos especialistas trabalhando integrados para uma solução completa e segura, cobrindo todos os aspectos técnicos do licenciamento."
          icon="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12.375 6.898a8.963 8.963 0 01-.031-2.533C12.446 2.018 13.88 0 15.5 0c.921 0 1.743.488 2.348 1.268.605.78.914 1.78.868 2.88a8.966 8.966 0 01-2.31 5.98M12.375 6.898a8.963 8.963 0 012.533-.031c1.843.046 3.276 1.064 3.897 2.365.605 1.26.692 2.74.232 4.088M12.375 6.898l-.097.281c-.261.768-.66 1.468-1.177 2.063"
        />
        <DiferencialCard
          title="Relacionamento com INEA e Prefeituras"
          description="Protocolamos e acompanhamos processos junto ao INEA e às Secretarias Municipais de Meio Ambiente do Rio de Janeiro, conhecendo a burocracia local."
          icon="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.031-.057-2.062-.168-3.063M12 2.25c.912.913 1.919 1.713 3.002 2.381"
        />
        <DiferencialCard
          title="Atendimento em Todo o Estado"
          description="Onde seu empreendimento estiver, nossa equipe vai até você. Atendimento presencial e remoto flexível, adaptado às necessidades do projeto."
          icon="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"
        />
      </div>
    </div>
  </section>

  <!-- SOBRE NÓS (RESUMO) -->
  <section class="section-luxury bg-cream">
    <div class="section-inner">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <div class="lg:col-span-7">
          <div class="deco-line mb-8"></div>
          <h2 class="text-4xl md:text-5xl font-display font-bold text-charcoal mb-8 tracking-tight">
            Quem é a <span class="text-deep-700">{SITE_CONFIG.company.shortName}</span>
          </h2>
          <div class="space-y-5 text-lg text-charcoal/60 leading-relaxed">
            <p>
              A {SITE_CONFIG.company.shortName} é uma consultoria ambiental sediada no Rio de Janeiro, com atuação em todo o estado. Há mais de 15 anos, auxiliamos empresas de diversos setores — indústria, construção civil, comércio, hotéis e infraestrutura — a navegarem pela burocracia ambiental municipal e estadual com eficiência.
            </p>
            <p>
              Nosso foco não é decorar artigos de lei federal. É <strong class="text-charcoal">protocolar e acompanhar processos junto ao INEA e às Secretarias Municipais de Meio Ambiente</strong>, resolver exigências técnicas, antecipar gargalos e garantir que a documentação do seu empreendimento seja aprovada no menor prazo possível.
            </p>
          </div>
          <div class="mt-10">
            <a
              href="/sobre"
              class="btn-luxury-outline"
            >
              Conheça Nossa Trajetória
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>

        <div class="lg:col-span-5">
          <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-br from-deep-900 to-forest-800 rounded-[2.5rem] opacity-10 blur-2xl"></div>
            <div class="relative bg-gradient-to-br from-deep-900 to-forest-800 rounded-[2.5rem] p-10 lg:p-14 text-white overflow-hidden">
              <div class="absolute inset-0 noise-overlay"></div>
              <div class="relative z-10 space-y-8">
                <div class="flex items-center gap-5">
                  <div class="w-14 h-14 rounded-2xl bg-gold-400/10 flex items-center justify-center text-gold-400 font-display font-bold text-xl shrink-0">200+</div>
                  <div>
                    <p class="font-bold text-white">Empreendimentos Regularizados</p>
                    <p class="text-white/50 text-sm">Desde 2010</p>
                  </div>
                </div>
                <div class="flex items-center gap-5">
                  <div class="w-14 h-14 rounded-2xl bg-gold-400/10 flex items-center justify-center text-gold-400 font-display font-bold text-xl shrink-0">98%</div>
                  <div>
                    <p class="font-bold text-white">Taxa de Aprovação</p>
                    <p class="text-white/50 text-sm">Na primeira submissão</p>
                  </div>
                </div>
                <div class="flex items-center gap-5">
                  <div class="w-14 h-14 rounded-2xl bg-gold-400/10 flex items-center justify-center text-gold-400 font-display font-bold text-xl shrink-0">15+</div>
                  <div>
                    <p class="font-bold text-white">Anos de Experiência</p>
                    <p class="text-white/50 text-sm">No mercado fluminense</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVIÇOS -->
  <section class="section-luxury bg-paper">
    <div class="section-inner">
      <div class="text-center mb-20">
        <div class="deco-line mx-auto mb-8"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-charcoal mb-6 tracking-tight">Nossos Serviços</h2>
        <p class="text-lg text-charcoal/50 max-w-2xl mx-auto">Soluções ambientais completas para cada etapa da regularização do seu negócio.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {servicos.map((servico) => (
          <a href={`/servicos/${servico.slug}`} class="group">
            <Card
              title={servico.data.title}
              description={servico.data.description}
              icon={servico.data.icon}
            />
          </a>
        ))}
      </div>

      <div class="text-center mt-16">
        <a
          href="/servicos"
          class="btn-luxury-outline"
        >
          Ver Todos os Serviços
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CLIENTES -->
  <section class="section-luxury bg-cream">
    <div class="section-inner">
      <div class="text-center mb-20">
        <div class="deco-line mx-auto mb-8"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-charcoal mb-6 tracking-tight">Empresas que confiam na {SITE_CONFIG.company.shortName}</h2>
        <p class="text-lg text-charcoal/50 max-w-2xl mx-auto">Atuamos junto a grandes indústrias, construtoras, redes varejistas, concessionárias e empreendimentos hoteleiros no Rio de Janeiro.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-6 items-center">
        {[
          'Honda', 'BMW', 'Chevrolet', 'Cedae', 'Atacadão', 'Megafor',
          'Royalty Barra Hotel', 'Construtora Vitale', 'Camil', 'GE Celma',
          'Atel Imóveis', 'Tecnosol', 'BRT'
        ].map((cliente) => (
          <div class="glass-card p-6 rounded-2xl text-center">
            <p class="font-display font-bold text-charcoal text-sm md:text-base">{cliente}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section-luxury bg-paper">
    <div class="section-inner">
      <CTABox />
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
