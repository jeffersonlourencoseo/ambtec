---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import SchemaReview from '../components/SchemaReview.astro';
import { SITE_CONFIG } from '../data/config.ts';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.company.whatsapp}?text=${encodeURIComponent('Olá, vi o site no google e gostaria de mais informações!')}`;

const servicos = [
  {
    num: '01',
    title: 'Licenciamento Ambiental',
    desc: 'LP, LI, LO, EIA/RIMA e protocolo junto ao INEA e prefeituras.',
    href: '/servicos/licenciamento-ambiental',
  },
  {
    num: '02',
    title: 'Compensação Ambiental',
    desc: 'Plano, cálculo e execução de ações compensatórias exigidas na licença.',
    href: '/servicos/compensacao-ambiental',
  },
  {
    num: '03',
    title: 'Inventário Florestal e Fauna',
    desc: 'Levantamento científico que subsidia o licenciamento e a compensação.',
    href: '/servicos/inventario-florestal-e-fauna',
  },
  {
    num: '04',
    title: 'Podas e Supressão Vegetal',
    desc: 'Laudo técnico, autorização e execução de cortes legais para obras licenciadas.',
    href: '/servicos/podas-e-supressao-vegetal',
  },
  {
    num: '05',
    title: 'Reflorestamento e Recuperação',
    desc: 'Plantio de espécies nativas e monitoramento de áreas recuperadas.',
    href: '/servicos/reflorestamento',
  },
];

const clientes = [
  'Honda', 'BMW', 'Chevrolet', 'Cedae', 'Atacadão', 'Megafor',
  'Royalty Barra', 'Construtora Vitale', 'Camil', 'GE Celma',
  'Atel Imóveis', 'Tecnosol', 'BRT'
];
---

<Layout
  title={SITE_CONFIG.seo.defaultTitle}
  description="Consultoria ambiental no Rio de Janeiro. Licenciamento junto ao INEA e Secretarias Municipais, mais compensação ambiental, inventário florestal, podas legalizadas e reflorestamento. Tudo em um só lugar."
>
  <Fragment slot="header"><Header /></Fragment>

  <SchemaReview
    itemReviewed={SITE_CONFIG.company.name}
    reviews={[
      {
        author: 'Roberto Mendes',
        datePublished: '2024-03-15',
        reviewBody: 'A Ambtec conduziu todo o processo de licenciamento da nossa indústria com extrema competência. Conseguimos a liberação dentro do prazo e sem retrabalho.',
        reviewRating: 5,
      },
      {
        author: 'Luciana Costa',
        datePublished: '2024-08-22',
        reviewBody: 'Profissionalismo e transparência em cada etapa. O licenciamento ambiental da nossa empresa foi resolvido sem complicações e hoje operamos 100% regularizados.',
        reviewRating: 5,
      },
      {
        author: 'Fernando Oliveira',
        datePublished: '2025-01-10',
        reviewBody: 'Contratamos para o EIA/RIMA de um grande empreendimento. O rigor técnico impressionou até os órgãos ambientais. Resultado: aprovação na primeira submissão.',
        reviewRating: 5,
      },
    ]}
  />

  <!-- ============================================ -->
  <!-- HERO — TIPOGRAFIA MONUMENTAL                 -->
  <!-- ============================================ -->
  <section class="relative min-h-screen flex flex-col justify-end bg-[#080c0a] overflow-hidden">
    <!-- Textura de grão -->
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 200 200\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'n\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23n)\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 150px 150px;"
    ></div>

    <!-- Linha vertical decorativa -->
    <div class="absolute left-8 md:left-16 top-0 bottom-0 w-px bg-white/[0.06]"></div>

    <div class="relative z-10 px-8 md:px-16 pb-16 md:pb-24 pt-40">
      <div class="max-w-6xl">
        <!-- Eyebrow -->
        <div class="mb-8 flex items-center gap-4">
          <span class="w-12 h-px bg-[#c9a84c]"></span>
          <span class="text-[#c9a84c] text-xs font-medium tracking-[0.2em] uppercase">Consultoria Ambiental — Rio de Janeiro</span>
        </div>

        <!-- Headline monumental -->
        <h1 class="font-display text-[clamp(3.5rem,11vw,10rem)] font-bold text-[#f0ebe3] tracking-[-0.04em] leading-[0.88] mb-10">
          Regularize
          <br />
          seu empreendimento<span class="text-[#c9a84c]">.</span>
        </h1>

        <!-- Subtitle + CTAs -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
          <div class="lg:col-span-6">
            <p class="text-lg md:text-xl text-[#f0ebe3]/40 leading-relaxed max-w-lg">
              Licenciamento junto ao <span class="text-[#f0ebe3]/70">INEA</span> e Secretarias Municipais. Quando necessário, executamos no terreno: compensação, inventário florestal, podas e reflorestamento.
            </p>
          </div>
          <div class="lg:col-span-6 flex flex-wrap gap-4 lg:justify-end">
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-8 py-4 bg-[#c9a84c] text-[#080c0a] font-bold text-sm tracking-wide rounded-none hover:bg-[#d4b862] transition-colors duration-300">
              Solicitar Orçamento
            </a>
            <a href="/servicos"
              class="inline-flex items-center justify-center px-8 py-4 border border-[#f0ebe3]/20 text-[#f0ebe3] font-bold text-sm tracking-wide rounded-none hover:border-[#c9a84c] hover:text-[#c9a84c] transition-colors duration-300">
              Conhecer Serviços
            </a>
          </div>
        </div>

        <!-- Stats na borda inferior -->
        <div class="mt-20 pt-8 border-t border-white/[0.06] flex flex-wrap gap-x-16 gap-y-4">
          <div class="flex items-baseline gap-3">
            <span class="text-4xl md:text-5xl font-display font-bold text-[#c9a84c]">200+</span>
            <span class="text-sm text-[#f0ebe3]/30 uppercase tracking-wider">Empreendimentos</span>
          </div>
          <div class="flex items-baseline gap-3">
            <span class="text-4xl md:text-5xl font-display font-bold text-[#c9a84c]">98%</span>
            <span class="text-sm text-[#f0ebe3]/30 uppercase tracking-wider">Aprovação</span>
          </div>
          <div class="flex items-baseline gap-3">
            <span class="text-4xl md:text-5xl font-display font-bold text-[#c9a84c]">15+</span>
            <span class="text-sm text-[#f0ebe3]/30 uppercase tracking-wider">Anos</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 right-8 md:right-16 flex flex-col items-center gap-2 text-[#f0ebe3]/20">
      <span class="text-[10px] uppercase tracking-[0.2em] rotate-90 origin-center translate-y-8">Scroll</span>
      <div class="w-px h-12 bg-gradient-to-b from-[#c9a84c]/50 to-transparent"></div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SERVIÇOS — LISTA EDITORIAL COM NÚMEROS      -->
  <!-- ============================================ -->
  <section class="relative bg-[#0f1a14] border-t border-white/[0.06]">
    <div class="px-8 md:px-16 py-24 md:py-32">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
          <!-- Header fixo -->
          <div class="lg:col-span-4">
            <div class="lg:sticky lg:top-32">
              <div class="flex items-center gap-4 mb-6">
                <span class="w-12 h-px bg-[#c9a84c]"></span>
                <span class="text-[#c9a84c] text-xs font-medium tracking-[0.2em] uppercase">Serviços</span>
              </div>
              <h2 class="text-4xl md:text-5xl font-display font-bold text-[#f0ebe3] tracking-tight leading-[1] mb-6">
                Do Licenciamento à Execução
              </h2>
              <p class="text-[#f0ebe3]/40 leading-relaxed mb-8">
                Cinco especialidades técnicas interligadas. Uma equipe, um cronograma, uma responsabilidade.
              </p>
              <a href="/servicos"
                class="inline-flex items-center justify-center px-6 py-3 border border-[#f0ebe3]/20 text-[#f0ebe3] font-bold text-sm tracking-wide rounded-none hover:border-[#c9a84c] hover:text-[#c9a84c] transition-colors duration-300">
                Ver Todos
              </a>
            </div>
          </div>

          <!-- Lista -->
          <div class="lg:col-span-8">
            <div class="divide-y divide-white/[0.06]">
              {servicos.map((s) => (
                <a href={s.href} class="group block py-10 transition-colors duration-300 hover:bg-white/[0.02] -mx-4 px-4">
                  <div class="flex items-start gap-8">
                    <span class="text-5xl md:text-7xl font-display font-bold text-[#f0ebe3]/[0.04] group-hover:text-[#c9a84c]/20 transition-colors duration-500 leading-none select-none">
                      {s.num}
                    </span>
                    <div class="flex-1 pt-2">
                      <h3 class="text-xl md:text-2xl font-display font-bold text-[#f0ebe3] mb-2 group-hover:text-[#c9a84c] transition-colors duration-300">
                        {s.title}
                      </h3>
                      <p class="text-[#f0ebe3]/40 leading-relaxed max-w-md">
                        {s.desc}
                      </p>
                    </div>
                    <svg class="w-6 h-6 text-[#f0ebe3]/10 group-hover:text-[#c9a84c] group-hover:translate-x-1 transition-all duration-300 shrink-0 mt-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SOBRE — ASYMMETRIC SPLIT                     -->
  <!-- ============================================ -->
  <section class="relative bg-[#080c0a] border-t border-white/[0.06]">
    <div class="px-8 md:px-16 py-24 md:py-32">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
          <!-- Texto -->
          <div class="lg:col-span-7">
            <div class="flex items-center gap-4 mb-6">
              <span class="w-12 h-px bg-[#c9a84c]"></span>
              <span class="text-[#c9a84c] text-xs font-medium tracking-[0.2em] uppercase">Sobre</span>
            </div>
            <h2 class="text-4xl md:text-5xl font-display font-bold text-[#f0ebe3] tracking-tight leading-[1] mb-8">
              Quem é a <span class="text-[#5a8a6e]">{SITE_CONFIG.company.shortName}</span>
            </h2>
            <div class="space-y-5 text-lg text-[#f0ebe3]/40 leading-relaxed max-w-xl">
              <p>
                A <span class="text-[#f0ebe3]/70">{SITE_CONFIG.company.shortName}</span> é uma consultoria ambiental sediada no Rio de Janeiro. Há mais de 15 anos, auxiliamos empresas de diversos setores a <strong class="text-[#f0ebe3]">licenciarem, compensarem, inventariarem e recuperarem áreas ambientais</strong>.
              </p>
              <p>
                Nosso diferencial é a <strong class="text-[#f0ebe3]">integração</strong>: a mesma equipe que protocola sua licença é capaz de realizar o inventário florestal, executar a compensação e implantar reflorestamento. Sem retrabalho.
              </p>
            </div>
            <div class="mt-10">
              <a href="/sobre"
                class="inline-flex items-center justify-center px-6 py-3 border border-[#f0ebe3]/20 text-[#f0ebe3] font-bold text-sm tracking-wide rounded-none hover:border-[#c9a84c] hover:text-[#c9a84c] transition-colors duration-300">
                Conheça Nossa Trajetória
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            </div>
          </div>

          <!-- Painel escuro com números -->
          <div class="lg:col-span-5">
            <div class="bg-[#0f1a14] border border-white/[0.06] p-10 md:p-12">
              <div class="space-y-8">
                <div class="flex items-center gap-5">
                  <div class="w-16 h-16 border border-[#c9a84c]/20 flex items-center justify-center text-[#c9a84c] font-display font-bold text-2xl shrink-0">200+</div>
                  <div>
                    <p class="font-bold text-[#f0ebe3] text-lg">Empreendimentos Regularizados</p>
                    <p class="text-[#f0ebe3]/30 text-sm">Desde 2010</p>
                  </div>
                </div>
                <div class="flex items-center gap-5">
                  <div class="w-16 h-16 border border-[#c9a84c]/20 flex items-center justify-center text-[#c9a84c] font-display font-bold text-2xl shrink-0">98%</div>
                  <div>
                    <p class="font-bold text-[#f0ebe3] text-lg">Taxa de Aprovação</p>
                    <p class="text-[#f0ebe3]/30 text-sm">Na primeira submissão</p>
                  </div>
                </div>
                <div class="flex items-center gap-5">
                  <div class="w-16 h-16 border border-[#c9a84c]/20 flex items-center justify-center text-[#c9a84c] font-display font-bold text-2xl shrink-0">15+</div>
                  <div>
                    <p class="font-bold text-[#f0ebe3] text-lg">Anos de Experiência</p>
                    <p class="text-[#f0ebe3]/30 text-sm">No mercado fluminense</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CLIENTES — POESIA VISUAL                     -->
  <!-- ============================================ -->
  <section class="relative bg-[#0f1a14] border-t border-white/[0.06]">
    <div class="px-8 md:px-16 py-24 md:py-32">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center gap-4 mb-12">
          <span class="w-12 h-px bg-[#c9a84c]"></span>
          <span class="text-[#c9a84c] text-xs font-medium tracking-[0.2em] uppercase">Clientes</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-[#f0ebe3] tracking-tight leading-[1] mb-6 max-w-2xl">
          Empresas que confiam na {SITE_CONFIG.company.shortName}
        </h2>
        <p class="text-lg text-[#f0ebe3]/40 leading-relaxed mb-16 max-w-xl">
          Atuamos junto a grandes indústrias, construtoras, redes varejistas, concessionárias e empreendimentos hoteleiros.
        </p>

        <div class="flex flex-wrap gap-x-12 gap-y-4 items-baseline">
          {clientes.map((cliente, i) => (
            <span class="text-2xl md:text-3xl font-display text-[#f0ebe3]/20 hover:text-[#f0ebe3]/60 transition-colors duration-500 cursor-default">
              {cliente}
              {i < clientes.length - 1 && <span class="text-[#f0ebe3]/[0.04] ml-12">·</span>}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CTA FINAL — BLOCO MONOLÍTICO                 -->
  <!-- ============================================ -->
  <section class="relative bg-[#080c0a] border-t border-white/[0.06]">
    <div class="px-8 md:px-16 py-24 md:py-40">
      <div class="max-w-4xl mx-auto text-center">
        <div class="flex items-center justify-center gap-4 mb-8">
          <span class="w-12 h-px bg-[#c9a84c]"></span>
          <span class="text-[#c9a84c] text-xs font-medium tracking-[0.2em] uppercase">Contato</span>
          <span class="w-12 h-px bg-[#c9a84c]"></span>
        </div>
        <h2 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-[#f0ebe3] tracking-tight leading-[0.95] mb-8">
          Vamos regularizar seu empreendimento<span class="text-[#c9a84c]">.</span>
        </h2>
        <p class="text-lg text-[#f0ebe3]/40 leading-relaxed max-w-xl mx-auto mb-12">
          Cada projeto recebe diagnóstico técnico gratuito e proposta personalizada com cronograma realista.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-10 py-4 bg-[#c9a84c] text-[#080c0a] font-bold text-sm tracking-wide rounded-none hover:bg-[#d4b862] transition-colors duration-300">
            Falar no WhatsApp
          </a>
          <a href="/contato"
            class="inline-flex items-center justify-center px-10 py-4 border border-[#f0ebe3]/20 text-[#f0ebe3] font-bold text-sm tracking-wide rounded-none hover:border-[#c9a84c] hover:text-[#c9a84c] transition-colors duration-300">
            Enviar E-mail
          </a>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
