---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import DiferencialCard from '../components/DiferencialCard.astro';
import CTABox from '../components/CTABox.astro';
import SchemaReview from '../components/SchemaReview.astro';
import DecoRings from '../components/DecoRings.astro';
import { SITE_CONFIG } from '../data/config.ts';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.company.whatsapp}?text=${encodeURIComponent('Olá, vi o site no google e gostaria de mais informações!')}`;
---

<Layout
  title={SITE_CONFIG.seo.defaultTitle}
  description="Consultoria ambiental no Rio de Janeiro. Licenciamento junto ao INEA e Secretarias Municipais, mais compensação ambiental, inventário florestal, podas legalizadas e reflorestamento. Tudo em um só lugar."
>
  <Fragment slot="header"><Header /></Fragment>

  <SchemaReview
    itemReviewed={SITE_CONFIG.company.name}
    reviews={[
      {
        author: 'Roberto Mendes',
        datePublished: '2024-03-15',
        reviewBody: 'A Ambtec conduziu todo o processo de licenciamento da nossa indústria com extrema competência. Conseguimos a liberação dentro do prazo e sem retrabalho.',
        reviewRating: 5,
      },
      {
        author: 'Luciana Costa',
        datePublished: '2024-08-22',
        reviewBody: 'Profissionalismo e transparência em cada etapa. O licenciamento ambiental da nossa empresa foi resolvido sem complicações e hoje operamos 100% regularizados.',
        reviewRating: 5,
      },
      {
        author: 'Fernando Oliveira',
        datePublished: '2025-01-10',
        reviewBody: 'Contratamos para o EIA/RIMA de um grande empreendimento. O rigor técnico impressionou até os órgãos ambientais. Resultado: aprovação na primeira submissão.',
        reviewRating: 5,
      },
    ]}
  />

  <!-- HERO TIPOGRÁFICO -->
  <section class="relative min-h-screen flex items-end bg-brand-deep overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-deep via-brand-deep to-brand-mid/60"></div>
    <div class="absolute top-0 right-0 w-[50vw] h-[50vw] text-brand-light opacity-40 -translate-y-1/4 translate-x-1/4 pointer-events-none">
      <DecoRings class="w-full h-full" />
    </div>

    <div class="section-luxury relative z-10 w-full pb-8">
      <div class="section-inner">
        <div class="max-w-5xl">
          <div class="inline-flex items-center gap-3 px-4 py-2 mb-10 rounded-full border border-accent-gold/30 bg-accent-gold/10">
            <span class="w-1.5 h-1.5 rounded-full bg-accent-gold"></span>
            <span class="text-accent-gold text-xs font-medium tracking-[0.15em] uppercase">Consultoria Ambiental — Rio de Janeiro</span>
          </div>

          <h1 class="text-[clamp(3rem,10vw,8.5rem)] font-display font-bold text-white tracking-[-0.04em] leading-[0.88] mb-12">
            Regularize
            <br />
            seu empreendimento
            <span class="text-accent-gold">.</span>
          </h1>

          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
            <div class="lg:col-span-7">
              <p class="text-lg md:text-xl text-white/40 leading-relaxed max-w-xl">
                Licenciamento junto ao INEA e Secretarias Municipais.
                <span class="text-white/70">Quando necessário, executamos no terreno:</span> compensação, inventário florestal, podas e reflorestamento. Uma equipe, um cronograma, uma responsabilidade.
              </p>
            </div>

            <div class="lg:col-span-5 flex flex-wrap gap-4">
              <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-luxury">
                Solicitar Orçamento
              </a>
              <a href="/servicos" class="btn-luxury-dark">
                Conhecer Serviços
              </a>
            </div>
          </div>

          <div class="mt-24 pt-8 border-t border-white/10 flex flex-wrap gap-x-12 gap-y-4">
            <div class="flex items-baseline gap-2">
              <span class="text-3xl md:text-4xl font-display font-bold text-accent-gold">200+</span>
              <span class="text-sm text-white/30">Empreendimentos</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-3xl md:text-4xl font-display font-bold text-accent-gold">98%</span>
              <span class="text-sm text-white/30">Aprovação</span>
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-3xl md:text-4xl font-display font-bold text-accent-gold">15+</span>
              <span class="text-sm text-white/30">Anos</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DIFERENCIAIS -->
  <section class="section-luxury bg-neutral-paper">
    <div class="section-inner">
      <div class="text-center mb-20">
        <div class="deco-line mx-auto mb-8"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-neutral-ink mb-6 tracking-tight">
          Por que empresas confiam na {SITE_CONFIG.company.shortName}?
        </h2>
        <p class="text-lg text-neutral-ink-muted max-w-2xl mx-auto">Técnica integrada que vai do licenciamento à execução prática no terreno. Uma equipe, um cronograma, uma responsabilidade.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
        <DiferencialCard
          title="Diagnóstico Técnico Especializado"
          description="Após o primeiro contato, nossa equipe técnica analisa as particularidades do seu empreendimento e apresenta uma proposta detalhada com cronograma realista."
          icon="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
        />
        <DiferencialCard
          title="Equipe Multidisciplinar"
          description="Engenheiros ambientais e biólogos especialistas trabalhando integrados para uma solução completa e segura, cobrindo todos os aspectos técnicos do licenciamento."
          icon="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12.375 6.898a8.963 8.963 0 01-.031-2.533C12.446 2.018 13.88 0 15.5 0c.921 0 1.743.488 2.348 1.268.605.78.914 1.78.868 2.88a8.966 8.966 0 01-2.31 5.98M12.375 6.898a8.963 8.963 0 012.533-.031c1.843.046 3.276 1.064 3.897 2.365.605 1.26.692 2.74.232 4.088M12.375 6.898l-.097.281c-.261.768-.66 1.468-1.177 2.063"
        />
        <DiferencialCard
          title="Tudo para Licenciar em um Só Lugar"
          description="Do laudo ao plantio, do inventário à compensação. Nossa equipe integra licenciamento, estudos técnicos e execução prática — sem atrasos causados por fornecedores separados."
          icon="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.031-.057-2.062-.168-3.063M12 2.25c.912.913 1.919 1.713 3.002 2.381"
        />
        <DiferencialCard
          title="Atendimento em Todo o Estado"
          description="Onde seu empreendimento estiver, nossa equipe vai até você. Atendimento presencial e remoto flexível, adaptado às necessidades do projeto."
          icon="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"
        />
      </div>
    </div>
  </section>

  <!-- SOBRE NÓS — QUEBRA DE GRID -->
  <section class="section-luxury bg-neutral-cream overflow-hidden">
    <div class="section-inner">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        <div class="lg:col-span-6">
          <div class="deco-line mb-8"></div>
          <h2 class="text-4xl md:text-5xl font-display font-bold text-neutral-ink mb-8 tracking-tight">
            Quem é a <span class="text-brand-mid">{SITE_CONFIG.company.shortName}</span>
          </h2>
          <div class="space-y-5 text-lg text-neutral-ink-muted leading-relaxed">
            <p>
              A {SITE_CONFIG.company.shortName} é uma consultoria ambiental sediada no Rio de Janeiro. Há mais de 15 anos, auxiliamos empresas de diversos setores — indústria, construção civil, comércio, hotéis e infraestrutura — a <strong class="text-neutral-ink">licenciarem, compensarem, inventariarem e recuperarem áreas ambientais</strong>. Não somos apenas despachantes de processo. Somos técnicos que executam.
            </p>
            <p>
              Nosso diferencial é a <strong class="text-neutral-ink">integração</strong>: a mesma equipe que protocola sua licença no INEA ou na Secretaria Municipal é capaz de realizar o inventário florestal, executar a compensação ambiental, autorizar podas de árvores e implantar reflorestamento. Isso elimina retrabalho, reduz prazos e garante que cada documento entregue ao órgão ambiental tenha coerência técnica.
            </p>
          </div>
          <div class="mt-10">
            <a href="/sobre" class="btn-luxury-outline">
              Conheça Nossa Trajetória
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Painel escuro vazando para fora do container -->
    <div class="mt-16 lg:mt-0 lg:absolute lg:right-0 lg:top-1/2 lg:-translate-y-1/2 lg:w-[45%] xl:w-[40%] relative">
      <div class="bg-gradient-to-br from-brand-deep to-brand-mid p-10 lg:p-14 text-white overflow-hidden lg:rounded-l-2xl">
        <div class="absolute inset-0 noise-overlay"></div>
        <div class="relative z-10 space-y-8 max-w-md ml-auto">
          <div class="flex items-center gap-5">
            <div class="w-14 h-14 rounded-2xl bg-accent-gold/10 flex items-center justify-center text-accent-gold font-display font-bold text-xl shrink-0">200+</div>
            <div>
              <p class="font-bold text-white">Empreendimentos Regularizados</p>
              <p class="text-white/50 text-sm">Desde 2010</p>
            </div>
          </div>
          <div class="flex items-center gap-5">
            <div class="w-14 h-14 rounded-2xl bg-accent-gold/10 flex items-center justify-center text-accent-gold font-display font-bold text-xl shrink-0">98%</div>
            <div>
              <p class="font-bold text-white">Taxa de Aprovação</p>
              <p class="text-white/50 text-sm">Na primeira submissão</p>
            </div>
          </div>
          <div class="flex items-center gap-5">
            <div class="w-14 h-14 rounded-2xl bg-accent-gold/10 flex items-center justify-center text-accent-gold font-display font-bold text-xl shrink-0">15+</div>
            <div>
              <p class="font-bold text-white">Anos de Experiência</p>
              <p class="text-white/50 text-sm">No mercado fluminense</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVIÇOS — LISTA EDITORIAL -->
  <section class="section-luxury bg-neutral-paper">
    <div class="section-inner">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        <!-- Cabeçalho fixo à esquerda -->
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-32">
            <div class="deco-line mb-8"></div>
            <h2 class="text-4xl md:text-5xl font-display font-bold text-neutral-ink mb-6 tracking-tight">
              Do Licenciamento à Execução
            </h2>
            <p class="text-lg text-neutral-ink-muted leading-relaxed mb-10">
              Para aprovar uma licença, seu empreendimento pode precisar de muito mais que papelada. A Ambtec oferece <strong class="text-neutral-ink">5 especialidades interligadas</strong> — do estudo ao plantio, do laudo ao protocolo.
            </p>
            <a href="/servicos" class="btn-luxury-outline">
              Ver Todos os Serviços
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>

        <!-- Lista de serviços -->
        <div class="lg:col-span-8">
          <div class="space-y-0 divide-y divide-neutral-ink/10">
            <a href="/servicos/licenciamento-ambiental" class="group block py-10 transition-colors hover:bg-neutral-cream -mx-6 px-6 rounded-xl">
              <div class="flex items-start gap-8">
                <span class="text-5xl md:text-6xl font-display font-bold text-neutral-ink/10 group-hover:text-accent-gold/30 transition-colors">01</span>
                <div class="flex-1">
                  <h3 class="text-2xl font-display font-bold text-neutral-ink mb-3 group-hover:text-brand-mid transition-colors">Licenciamento Ambiental</h3>
                  <p class="text-neutral-ink-muted leading-relaxed max-w-lg">LP, LI, LO, EIA/RIMA e protocolo junto ao INEA e prefeituras. Da viabilidade à operação.</p>
                </div>
                <svg class="w-6 h-6 text-neutral-ink/20 group-hover:text-accent-gold group-hover:translate-x-1 transition-all shrink-0 mt-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </div>
            </a>

            <a href="/servicos/compensacao-ambiental" class="group block py-10 transition-colors hover:bg-neutral-cream -mx-6 px-6 rounded-xl">
              <div class="flex items-start gap-8">
                <span class="text-5xl md:text-6xl font-display font-bold text-neutral-ink/10 group-hover:text-accent-gold/30 transition-colors">02</span>
                <div class="flex-1">
                  <h3 class="text-2xl font-display font-bold text-neutral-ink mb-3 group-hover:text-brand-mid transition-colors">Compensação Ambiental</h3>
                  <p class="text-neutral-ink-muted leading-relaxed max-w-lg">Plano, cálculo e execução de ações compensatórias exigidas na licença. RPPN, restauração e CRAs.</p>
                </div>
                <svg class="w-6 h-6 text-neutral-ink/20 group-hover:text-accent-gold group-hover:translate-x-1 transition-all shrink-0 mt-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </div>
            </a>

            <a href="/servicos/inventario-florestal-e-fauna" class="group block py-10 transition-colors hover:bg-neutral-cream -mx-6 px-6 rounded-xl">
              <div class="flex items-start gap-8">
                <span class="text-5xl md:text-6xl font-display font-bold text-neutral-ink/10 group-hover:text-accent-gold/30 transition-colors">03</span>
                <div class="flex-1">
                  <h3 class="text-2xl font-display font-bold text-neutral-ink mb-3 group-hover:text-brand-mid transition-colors">Inventário Florestal e Fauna</h3>
                  <p class="text-neutral-ink-muted leading-relaxed max-w-lg">Levantamento científico que subsidia o licenciamento e a compensação. Relatórios para protocolo e publicação.</p>
                </div>
                <svg class="w-6 h-6 text-neutral-ink/20 group-hover:text-accent-gold group-hover:translate-x-1 transition-all shrink-0 mt-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </div>
            </a>

            <a href="/servicos/podas-e-supressao-vegetal" class="group block py-10 transition-colors hover:bg-neutral-cream -mx-6 px-6 rounded-xl">
              <div class="flex items-start gap-8">
                <span class="text-5xl md:text-6xl font-display font-bold text-neutral-ink/10 group-hover:text-accent-gold/30 transition-colors">04</span>
                <div class="flex-1">
                  <h3 class="text-2xl font-display font-bold text-neutral-ink mb-3 group-hover:text-brand-mid transition-colors">Podas e Supressão Vegetal</h3>
                  <p class="text-neutral-ink-muted leading-relaxed max-w-lg">Laudo técnico, autorização do INEA ou prefeitura, e execução com equipe treinada e EPIs adequados.</p>
                </div>
                <svg class="w-6 h-6 text-neutral-ink/20 group-hover:text-accent-gold group-hover:translate-x-1 transition-all shrink-0 mt-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </div>
            </a>

            <a href="/servicos/reflorestamento" class="group block py-10 transition-colors hover:bg-neutral-cream -mx-6 px-6 rounded-xl">
              <div class="flex items-start gap-8">
                <span class="text-5xl md:text-6xl font-display font-bold text-neutral-ink/10 group-hover:text-accent-gold/30 transition-colors">05</span>
                <div class="flex-1">
                  <h3 class="text-2xl font-display font-bold text-neutral-ink mb-3 group-hover:text-brand-mid transition-colors">Reflorestamento e Recuperação</h3>
                  <p class="text-neutral-ink-muted leading-relaxed max-w-lg">Plantio de espécies nativas, monitoramento de sobrevivência e relatórios técnicos para órgãos ambientais.</p>
                </div>
                <svg class="w-6 h-6 text-neutral-ink/20 group-hover:text-accent-gold group-hover:translate-x-1 transition-all shrink-0 mt-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CLIENTES — LISTA EDITORIAL -->
  <section class="section-luxury bg-neutral-cream">
    <div class="section-inner">
      <div class="max-w-4xl mb-16">
        <div class="deco-line mb-8"></div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-neutral-ink mb-6 tracking-tight">
          Empresas que confiam na {SITE_CONFIG.company.shortName}
        </h2>
        <p class="text-lg text-neutral-ink-muted leading-relaxed">
          Atuamos junto a grandes indústrias, construtoras, redes varejistas, concessionárias e empreendimentos hoteleiros no Rio de Janeiro.
        </p>
      </div>

      <div class="flex flex-wrap gap-x-10 gap-y-6 items-baseline">
        {[
          'Honda', 'BMW', 'Chevrolet', 'Cedae', 'Atacadão', 'Megafor',
          'Royalty Barra', 'Construtora Vitale', 'Camil', 'GE Celma',
          'Atel Imóveis', 'Tecnosol', 'BRT'
        ].map((cliente, i) => (
          <span class="text-xl md:text-2xl font-display text-neutral-ink/30 hover:text-neutral-ink transition-colors duration-500 cursor-default">
            {cliente}
            {i < 12 && <span class="text-neutral-ink/10 ml-10">·</span>}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section-luxury bg-neutral-paper">
    <div class="section-inner">
      <CTABox />
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
