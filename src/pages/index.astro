---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import Card from '../components/Card.astro';
import DiferencialCard from '../components/DiferencialCard.astro';
import DepoimentoCard from '../components/DepoimentoCard.astro';
import CTABox from '../components/CTABox.astro';
import { getCollection } from 'astro:content';
import { SITE_CONFIG } from '../data/config.ts';

const servicos = await getCollection('servicos');
const whatsappUrl = `https://wa.me/${SITE_CONFIG.company.whatsapp}?text=${encodeURIComponent('Olá, vi o site no google e gostaria de mais informações')}`;
---

<Layout
  title={SITE_CONFIG.seo.defaultTitle}
  description={SITE_CONFIG.seo.defaultDescription}
>
  <Fragment slot="header"><Header /></Fragment>

  <!-- HERO -->
  <section class="relative">
    <div class="section-inner">
      <div class="inline-flex items-center px-4 py-2 mb-8 bg-primary-100 text-primary-700 font-semibold text-sm rounded-full">
        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        Líder em Licenciamento Ambiental
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter leading-tight mb-8 text-gray-900 max-w-4xl">
        Regularize seu Empreendimento com Quem Entende de <span class="text-secondary-900">Ambiente</span>
      </h1>

      <p class="text-lg md:text-xl text-gray-600 max-w-2xl mb-10 leading-relaxed">
        Mais de 200 empresas já confiaram na {SITE_CONFIG.company.shortName} para tirar licenças, regularizar propriedades e dormir tranquila com o meio ambiente. Diagnóstico gratuito em até 24h.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-5 bg-green-500 text-white font-bold rounded-xl hover:bg-green-600 hover:scale-105 active:scale-95 transition-all shadow-lg shadow-green-500/20"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Solicitar Orçamento no WhatsApp
        </a>
        <a
          href="/servicos"
          class="inline-flex items-center justify-center px-8 py-5 border-2 border-gray-200 text-gray-700 font-bold rounded-xl hover:border-secondary-900 hover:text-secondary-900 hover:scale-105 active:scale-95 transition-all"
        >
          Ver Todos os Serviços
        </a>
      </div>
    </div>
  </section>

  <!-- DIFERENCIAIS -->
  <section class="bg-gray-50">
    <div class="section-inner">
      <div class="text-center mb-12 lg:mb-16">
        <h2 class="text-3xl md:text-4xl font-black tracking-tighter text-gray-900 mb-4">Por que escolher a {SITE_CONFIG.company.shortName}?</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">A consultoria ambiental que resolve, não apenas assessora.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
        <DiferencialCard
          title="Diagnóstico em 24h"
          description="Resposta rápida para sua urgência. Analisamos seu caso em até 1 dia útil e entregamos um plano de ação claro."
          icon="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
        />
        <DiferencialCard
          title="Equipe Multidisciplinar"
          description="Engenheiros, biólogos e advogados ambientais trabalhando juntos para uma solução completa e segura."
          icon="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0z"
        />
        <DiferencialCard
          title="Licença Aprovada ou Reembolso"
          description="Confiança total no nosso trabalho. Se não aprovarmos sua licença no prazo acordado, devolvemos o investimento."
          icon="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
        />
        <DiferencialCard
          title="Atendimento em Todo o Estado"
          description="Onde seu empreendimento estiver, nossa equipe vai até você. Atendimento presencial e remoto flexível."
          icon="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"
        />
      </div>
    </div>
  </section>

  <!-- SOBRE NÓS (RESUMO) -->
  <section>
    <div class="section-inner">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-6">
            Quem é a <span class="text-secondary-900">{SITE_CONFIG.company.shortName}</span>
          </h2>
          <div class="space-y-4 text-lg text-gray-600 leading-relaxed">
            <p>
              Nascemos com uma missão clara: <strong class="text-gray-900">tirar a burocracia ambiental do caminho dos empreendedores</strong>. Hoje somos uma equipe multidisciplinar que já regularizou mais de 200 empreendimentos.
            </p>
            <p>
              De indústrias a propriedades rurais, de pequenas obras a grandes empreendimentos, entregamos licenças, CARs e laudos com <strong class="text-gray-900">rigor técnico e prazos respeitados</strong>.
            </p>
          </div>
          <div class="mt-8">
            <a
              href="/sobre"
              class="inline-flex items-center justify-center px-8 py-4 bg-secondary-900 text-white font-bold rounded-lg hover:bg-accent-900 hover:scale-105 active:scale-95 transition-all shadow-lg shadow-secondary-900/20"
            >
              Conheça nossa História →
            </a>
          </div>
        </div>

        <div class="bg-secondary-900 rounded-3xl p-10 lg:p-12 text-white">
          <div class="grid grid-cols-2 gap-8">
            <div class="text-center">
              <div class="text-4xl font-black text-primary-400 mb-2">200+</div>
              <div class="text-sm text-gray-100">Empreendimentos Regularizados</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-black text-primary-400 mb-2">98%</div>
              <div class="text-sm text-gray-100">Taxa de Aprovação de Licenças</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-black text-primary-400 mb-2">15+</div>
              <div class="text-sm text-gray-100">Anos de Experiência</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-black text-primary-400 mb-2">24h</div>
              <div class="text-sm text-gray-100">Prazo de Primeiro Diagnóstico</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NOSSOS SERVIÇOS -->
  <section class="bg-gray-50">
    <div class="section-inner">
      <div class="text-center mb-12 lg:mb-16">
        <h2 class="text-3xl md:text-4xl font-black tracking-tighter text-gray-900 mb-4">Nossos Serviços</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Soluções completas para cada etapa da regularização ambiental do seu negócio.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-12">
        {servicos.map((servico) => (
          <a href={`/servicos/${servico.slug}`} class="group">
            <Card
              title={servico.data.title}
              description={servico.data.description}
              icon={servico.data.icon}
            />
          </a>
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href="/servicos"
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-secondary-900 text-secondary-900 font-bold rounded-lg hover:bg-secondary-900 hover:text-white hover:scale-105 active:scale-95 transition-all"
        >
          Ver Todos os Serviços →
        </a>
      </div>
    </div>
  </section>

  <!-- DEPOIMENTOS -->
  <section>
    <div class="section-inner">
      <div class="text-center mb-12 lg:mb-16">
        <h2 class="text-3xl md:text-4xl font-black tracking-tighter text-gray-900 mb-4">O que dizem nossos clientes</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Empresas e empreendedores que já regularizaram com a {SITE_CONFIG.company.shortName}.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-12">
        <DepoimentoCard
          name="Roberto Mendes"
          role="Diretor Industrial — Agropecuária Mendes"
          initials="RM"
          text={`A ${SITE_CONFIG.company.shortName} conduziu todo o processo de licenciamento da nossa indústria com extrema competência. Conseguimos a liberação em tempo recorde e sem dor de cabeça.`}
        />
        <DepoimentoCard
          name="Luciana Costa"
          role="Proprietária Rural — Fazenda Santa Luzia"
          initials="LC"
          text="Profissionalismo e transparência em cada etapa. O CAR da nossa propriedade foi resolvido sem complicações e hoje temos acesso a todo o crédito rural."
        />
        <DepoimentoCard
          name="Fernando Oliveira"
          role="Gerente de Projetos — Construtora Oliveira"
          initials="FO"
          text="Contratamos para o EIA/RIMA de um grande empreendimento. O rigor técnico impressionou até os órgãos ambientais. Resultado: aprovação na primeira submissão."
        />
      </div>
    </div>
  </section>

  <!-- CHAMADA DE CONTATO FINAL -->
  <section class="bg-gray-50">
    <div class="section-inner">
      <CTABox />
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>

<WhatsAppButton />
